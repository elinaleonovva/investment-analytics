# =========================
# Common / Backend
# =========================
POSTGRES_DB=market_vision_db
POSTGRES_USER=market_vision_user
POSTGRES_PASSWORD=market_vision_password
POSTGRES_HOST=pgdb
POSTGRES_PORT=5432
DB_ENGINE=django.db.backends.postgresql

DEBUG=0
SECRET_KEY=change-me-to-strong-secret

ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# =========================
# Dev hints (manual run)
# =========================
# If you run backend locally with docker-compose.dev.yml:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# DEBUG=1

# =========================
# Frontend (optional)
# =========================
# REACT_APP_API_BASE_URL=http://localhost/api
